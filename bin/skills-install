#!/usr/bin/env python3
"""Install skills/plugins by assembling core + adapters into platform paths."""
from __future__ import annotations

import argparse
import os
import shutil
import sys
import tempfile
from pathlib import Path

ROOT_HINT = "core/manifest.yaml"


def find_root() -> Path:
    path = Path.cwd().resolve()
    for candidate in [path, *path.parents]:
        if (candidate / "core" / "manifest.yaml").is_file():
            return candidate
    raise SystemExit(f"Run from skills repo root ({ROOT_HINT} not found)")


def _assemble(root: Path, platform: str, dest: Path, plugins: list[str] | None = None) -> None:
    sys.path.insert(0, str(root / "tools" / "skills-export"))
    from skills_export.assemble import export_platform

    if dest.exists():
        shutil.rmtree(dest)
    dest.mkdir(parents=True, exist_ok=True)
    export_platform(root, platform, dest, plugins=plugins)


def _install_flat_from_plugins(plugin_tree: Path, targets: list[Path]) -> None:
    for target in targets:
        target = target.expanduser()
        target.mkdir(parents=True, exist_ok=True)
        for plugin_dir in sorted(plugin_tree.iterdir()):
            skills = plugin_dir / "skills"
            if not skills.is_dir():
                continue
            for skill in skills.iterdir():
                if skill.is_dir() and (skill / "SKILL.md").is_file():
                    dst = target / skill.name
                    if dst.exists():
                        shutil.rmtree(dst)
                    shutil.copytree(skill, dst)
        print(f"installed skills -> {target}")


def _install_cursor_plugins(root: Path, target: Path) -> None:
    with tempfile.TemporaryDirectory(prefix="skills-cursor-") as tmp:
        assembled = Path(tmp) / "out"
        _assemble(root, "cursor", assembled)
        target.mkdir(parents=True, exist_ok=True)
        for plugin_dir in assembled.iterdir():
            if not plugin_dir.is_dir() or plugin_dir.name.startswith("."):
                continue
            if not (plugin_dir / ".cursor-plugin").is_dir():
                continue
            dst = target / plugin_dir.name
            if dst.exists():
                shutil.rmtree(dst)
            shutil.copytree(plugin_dir, dst)
            print(f"installed cursor plugin -> {dst}")


def _install_claude_marketplace(root: Path, target: Path) -> None:
    with tempfile.TemporaryDirectory(prefix="skills-claude-") as tmp:
        assembled = Path(tmp) / "out"
        _assemble(root, "claude", assembled)
        plugins_dst = target / "plugins" / "claude"
        if target.exists():
            shutil.rmtree(target)
        plugins_dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copytree(assembled, plugins_dst)
        # Rewrite marketplace sources for installed layout
        import json

        market_src = plugins_dst / ".claude-plugin" / "marketplace.json"
        if market_src.is_file():
            data = json.loads(market_src.read_text(encoding="utf-8"))
            for entry in data.get("plugins", []):
                entry["source"] = f"./plugins/claude/{entry['name']}"
            market_dst = target / ".claude-plugin" / "marketplace.json"
            market_dst.parent.mkdir(parents=True, exist_ok=True)
            market_dst.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
            # remove nested marketplace from plugins copy
            shutil.rmtree(plugins_dst / ".claude-plugin", ignore_errors=True)
        print(f"installed claude marketplace -> {target}")
        print(f"In Claude Code: /plugin marketplace add {target}")


def _install_codex_plugins(root: Path, scope_root: Path) -> None:
    import json

    with tempfile.TemporaryDirectory(prefix="skills-codex-") as tmp:
        assembled = Path(tmp) / "out"
        _assemble(root, "codex", assembled)
        plugin_root = scope_root / "plugins" / "codex"
        if plugin_root.exists():
            shutil.rmtree(plugin_root)
        plugin_root.parent.mkdir(parents=True, exist_ok=True)
        # copy plugins without marketplace.json at top
        plugin_root.mkdir(parents=True)
        for item in assembled.iterdir():
            if item.name == "marketplace.json":
                continue
            if item.is_dir():
                shutil.copytree(item, plugin_root / item.name)
                print(f"installed codex plugin -> {plugin_root / item.name}")
        market_src = assembled / "marketplace.json"
        market_dst = scope_root / ".agents" / "plugins" / "marketplace.json"
        if market_src.is_file():
            data = json.loads(market_src.read_text(encoding="utf-8"))
            for entry in data.get("plugins", []):
                if isinstance(entry.get("source"), dict):
                    entry["source"]["path"] = f"./plugins/codex/{entry['name']}"
            market_dst.parent.mkdir(parents=True, exist_ok=True)
            market_dst.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
            print(f"installed codex marketplace -> {market_dst}")


def main() -> int:
    parser = argparse.ArgumentParser(description="Assemble and install portable skills")
    parser.add_argument("platform", choices=["cursor", "claude", "codex"])
    scope = parser.add_mutually_exclusive_group()
    scope.add_argument("--user", action="store_true")
    scope.add_argument("--project", nargs="?", const=Path.cwd(), type=Path, default=None)
    parser.add_argument(
        "--plugins",
        action="store_true",
        help="Install native plugins (assembled from core + adapters)",
    )
    args = parser.parse_args()
    root = find_root()

    if args.plugins:
        if args.platform == "cursor":
            target = Path.home() / ".cursor" / "plugins" / "local"
            _install_cursor_plugins(root, target)
            return 0
        if args.platform == "claude":
            target = (
                Path.home() / ".claude" / "marketplaces" / "dasobral-skills"
                if args.user
                else (args.project or Path.cwd()) / "claude-marketplace"
            )
            _install_claude_marketplace(root, target)
            return 0
        scope_root = Path.home() if args.user else (args.project or Path.cwd())
        _install_codex_plugins(root, scope_root)
        return 0

    # Flat skills install
    with tempfile.TemporaryDirectory(prefix="skills-flat-") as tmp:
        assembled = Path(tmp) / "out"
        _assemble(root, args.platform, assembled)
        if args.user:
            targets = {
                "cursor": [Path.home() / ".cursor" / "skills"],
                "claude": [Path.home() / ".claude" / "skills"],
                "codex": [
                    Path.home() / ".codex" / "skills",
                    Path.home() / ".agents" / "skills",
                ],
            }[args.platform]
        else:
            project = args.project or Path.cwd()
            targets = {
                "cursor": [project / ".cursor" / "skills"],
                "claude": [project / ".claude" / "skills"],
                "codex": [project / ".agents" / "skills"],
            }[args.platform]
        _install_flat_from_plugins(assembled, targets)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
