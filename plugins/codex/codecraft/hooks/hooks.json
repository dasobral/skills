{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/scripts/check_conventions_age.py",
            "timeout": 5,
            "statusMessage": "Checking repository conventions"
          }
        ]
      }
    ]
  }
}
