{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dasobral.example/schemas/claim-evidence-graph.schema.json",
  "title": "Claim-to-evidence graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["graph_id", "claim", "runs", "edges", "final_decision"],
  "properties": {
    "graph_id": {"type": "string", "minLength": 1},
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "statement", "context_of_use", "quantity_of_interest"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1},
        "context_of_use": {"type": "string", "minLength": 1},
        "quantity_of_interest": {"type": "string", "minLength": 1}
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["run_id", "run_record_path", "run_record_hash"],
        "properties": {
          "run_id": {"type": "string", "pattern": "^run-sha256:[0-9a-f]{64}$"},
          "run_record_path": {"type": "string", "minLength": 1},
          "run_record_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["edge_id", "assurance_activity", "test_id", "run_id", "artifact_path", "artifact_hash", "acceptance_criterion", "evidence_state", "reviewer_decision", "decision_source"],
        "properties": {
          "edge_id": {"type": "string", "minLength": 1},
          "assurance_activity": {"enum": ["code-verification", "solution-verification", "model-validation", "uncertainty-quantification"]},
          "test_id": {"type": "string", "minLength": 1},
          "run_id": {"type": "string", "pattern": "^run-sha256:[0-9a-f]{64}$"},
          "artifact_path": {"type": "string", "minLength": 1},
          "artifact_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "acceptance_criterion": {"type": "string", "minLength": 1},
          "evidence_state": {"enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]},
          "reviewer_decision": {"enum": ["accepted", "rejected", "deferred"]},
          "decision_source": {"enum": ["human-reviewer", "deterministic-check", "agent-analysis"]}
        }
      }
    },
    "final_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "decision_source", "rationale"],
      "properties": {
        "status": {"enum": ["accepted", "rejected", "review-required"]},
        "decision_source": {"enum": ["human-reviewer", "deterministic-check", "agent-analysis"]},
        "rationale": {"type": "string", "minLength": 1}
      }
    }
  }
}
