{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dasobral.example/schemas/unit-registry.schema.json",
  "title": "Unit registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["quantities"],
  "properties": {
    "quantities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "unit", "dimension", "coordinate_frame"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "unit": {"type": "string", "minLength": 1},
          "dimension": {"type": "string", "minLength": 1},
          "coordinate_frame": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
