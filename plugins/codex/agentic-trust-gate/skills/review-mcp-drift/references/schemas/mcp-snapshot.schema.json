{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/mcp-snapshot.schema.json",
  "title": "Sanitized MCP snapshot",
  "type": "object",
  "required": ["server"],
  "properties": {
    "server": {
      "type": "object",
      "required": ["tools"],
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description", "inputSchema"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "description": {"type": "string"},
              "inputSchema": {"type": "object"}
            },
            "additionalProperties": true
          }
        },
        "instructions": {"type": "string"},
        "auth_endpoint": {"type": "string"},
        "scopes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "token_passthrough": {"type": "boolean"},
        "package": {"type": "object"},
        "remote_descriptor": {"type": "object"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
