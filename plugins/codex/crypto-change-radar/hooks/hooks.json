{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|apply_patch|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/scripts/check_crypto_inputs.py",
            "timeout": 5,
            "statusMessage": "Identifying crypto evidence changes"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|apply_patch|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/scripts/check_crypto_inputs.py",
            "timeout": 5,
            "statusMessage": "Checking crypto inventory inputs"
          }
        ]
      }
    ]
  }
}
