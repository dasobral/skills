{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PQC migration review queue",
  "type": "object",
  "required": ["schema_version", "policy_revision", "ranking_method", "queue"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "policy_revision": {"type": "string"},
    "ranking_method": {"const": "v1:cl+sl+exposure+lead+(6-updateability)+dependency-count"},
    "queue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rank", "asset_id", "score", "evidence_state", "factors", "dependencies"],
        "properties": {
          "rank": {"type": "integer", "minimum": 1},
          "asset_id": {"type": "string"},
          "score": {"type": "number"},
          "evidence_state": {"enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]},
          "factors": {
            "type": "object",
            "required": ["confidentiality_lifetime_years", "system_lifetime_years", "updateability", "exposure", "migration_lead_time_years", "dependency_count"],
            "properties": {
              "confidentiality_lifetime_years": {"type": "number", "minimum": 0},
              "system_lifetime_years": {"type": "number", "minimum": 0},
              "updateability": {"type": "number", "minimum": 1},
              "exposure": {"type": "number", "minimum": 0},
              "migration_lead_time_years": {"type": "number", "minimum": 0},
              "dependency_count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": false
          },
          "dependencies": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
