{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/scripts/cpp_security_hint.py",
            "timeout": 5,
            "statusMessage": "Checking for C++ cryptographic risk"
          }
        ]
      }
    ]
  }
}
