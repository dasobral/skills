{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/replay-ledger-entry.schema.json",
  "title": "Authenticated append-only replay trust ledger entry",
  "type": "object",
  "required": [
    "schema_version",
    "sequence",
    "previous_entry_hmac",
    "bindings",
    "entry_hmac"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "sequence": {"type": "integer", "minimum": 1},
    "previous_entry_hmac": {"$ref": "#/$defs/hmac"},
    "bindings": {
      "type": "object",
      "required": ["scenario", "role_templates", "worker_envelopes", "observations", "summary"],
      "properties": {
        "scenario": {"$ref": "#/$defs/binding"},
        "role_templates": {
          "type": "object",
          "required": ["attacker", "victim", "judge"],
          "additionalProperties": {"$ref": "#/$defs/binding"}
        },
        "worker_envelopes": {
          "type": "object",
          "required": ["attacker", "victim", "judge"],
          "additionalProperties": {
            "type": "object",
            "required": ["sent", "received"],
            "properties": {
              "sent": {"type": "array", "items": {"$ref": "#/$defs/binding"}},
              "received": {"type": "array", "items": {"$ref": "#/$defs/binding"}}
            },
            "additionalProperties": false
          }
        },
        "observations": {
          "type": "array",
          "items": {
            "allOf": [
              {"$ref": "#/$defs/binding"},
              {
                "type": "object",
                "required": ["label"],
                "properties": {"label": {"type": "string", "pattern": "^observation:"}}
              }
            ]
          }
        },
        "summary": {"$ref": "#/$defs/binding"}
      },
      "additionalProperties": false
    },
    "entry_hmac": {"$ref": "#/$defs/hmac"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "hmac": {"type": "string", "pattern": "^hmac-sha256:[0-9a-f]{64}$"},
    "binding": {
      "type": "object",
      "required": ["hash", "hmac"],
      "properties": {
        "hash": {"$ref": "#/$defs/hash"},
        "hmac": {"$ref": "#/$defs/hmac"},
        "label": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
