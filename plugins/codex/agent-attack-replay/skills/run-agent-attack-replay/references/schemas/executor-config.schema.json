{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/executor-config.schema.json",
  "title": "Isolated agent executor configuration",
  "type": "object",
  "required": ["protocol_version", "input_manifest", "executors"],
  "properties": {
    "protocol_version": {"const": 1},
    "sandbox_executable": {"type": "string", "pattern": "^/"},
    "input_manifest": {
      "type": "object",
      "required": ["schema_version", "approved_input_root", "files", "manifest_digest"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "approved_input_root": {"type": "string", "pattern": "^/"},
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
              },
              "sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              }
            },
            "additionalProperties": false
          }
        },
        "manifest_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "executors": {
      "type": "object",
      "required": ["attacker", "victim", "judge"],
      "properties": {
        "attacker": {"$ref": "#/$defs/executor"},
        "victim": {"$ref": "#/$defs/executor"},
        "judge": {"$ref": "#/$defs/executor"}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "executor": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
