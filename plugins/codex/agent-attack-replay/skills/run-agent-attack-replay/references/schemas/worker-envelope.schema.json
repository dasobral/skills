{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/worker-envelope.schema.json",
  "title": "Role-isolated worker request envelope",
  "type": "object",
  "required": [
    "role",
    "role_definition_hash",
    "role_input",
    "planned_actions",
    "other_role_inputs",
    "monitor_context"
  ],
  "properties": {
    "role": {"enum": ["attacker", "victim", "judge"]},
    "role_definition_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "role_input": {"type": "object"},
    "planned_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "arguments"],
        "properties": {
          "tool": {"type": "string"},
          "arguments": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "other_role_inputs": {"type": ["object", "null"]},
    "monitor_context": {"type": ["object", "null"]}
  },
  "additionalProperties": false
}
