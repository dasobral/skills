{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/replay-plan.schema.json",
  "title": "Constrained replay plan",
  "type": "object",
  "required": ["trials"],
  "properties": {
    "trials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["trial_id", "role_actions"],
        "properties": {
          "trial_id": {"type": "string", "minLength": 1},
          "role_actions": {
            "type": "object",
            "required": ["attacker", "victim", "judge"],
            "properties": {
              "attacker": {"$ref": "#/$defs/actions"},
              "victim": {"$ref": "#/$defs/actions"},
              "judge": {"maxItems": 0, "$ref": "#/$defs/actions"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "arguments"],
        "properties": {
          "tool": {"type": "string", "minLength": 1},
          "arguments": {"type": "object"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
