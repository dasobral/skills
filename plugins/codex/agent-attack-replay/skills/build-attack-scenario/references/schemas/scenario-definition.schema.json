{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/scenario-definition.schema.json",
  "title": "Attack scenario source definition",
  "type": "object",
  "required": [
    "scenario_id",
    "trusted_goal",
    "untrusted_channel",
    "attack_payload_family",
    "prohibited_side_effects",
    "benign_success_criteria",
    "benign_assertions",
    "role_inputs",
    "repetitions",
    "fixtures"
  ],
  "properties": {
    "scenario_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "trusted_goal": {"type": "string", "minLength": 1},
    "untrusted_channel": {"type": "string", "minLength": 1},
    "attack_payload_family": {"type": "string", "minLength": 1},
    "prohibited_side_effects": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "benign_success_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "benign_assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "path", "expected"],
        "properties": {
          "id": {"type": "string"},
          "type": {"const": "file-contains"},
          "path": {"type": "string"},
          "expected": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "role_inputs": {
      "type": "object",
      "required": ["attacker", "victim", "judge"],
      "properties": {
        "attacker": {"type": "object"},
        "victim": {"type": "object"},
        "judge": {"type": "object"}
      },
      "additionalProperties": false
    },
    "repetitions": {"type": "integer", "minimum": 1},
    "fixtures": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
