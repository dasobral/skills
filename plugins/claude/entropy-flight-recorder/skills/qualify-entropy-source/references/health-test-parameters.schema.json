{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entropy source health-test parameters",
  "type": "object",
  "required": ["formula_version", "alphabet_size", "claimed_min_entropy_bits_per_sample", "repetition_count_cutoff", "adaptive_proportion_window", "adaptive_proportion_cutoff", "alpha"],
  "properties": {
    "formula_version": {"const": "NIST.SP.800-90B@2018:4.4.1-4.4.2/v1"},
    "alphabet_size": {"type": "integer", "minimum": 2},
    "claimed_min_entropy_bits_per_sample": {"type": "number", "exclusiveMinimum": 0},
    "repetition_count_cutoff": {"type": "integer", "minimum": 1},
    "adaptive_proportion_window": {"type": "integer", "minimum": 1},
    "adaptive_proportion_cutoff": {"type": "integer", "minimum": 1},
    "alpha": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"alphabet_size": {"const": 2}}},
      "then": {"properties": {"adaptive_proportion_window": {"const": 1024}}},
      "else": {"properties": {"adaptive_proportion_window": {"const": 512}}}
    }
  ],
  "additionalProperties": false
}
