{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CBOM semantic delta",
  "type": "object",
  "required": ["schema_version", "before_revision", "after_revision", "changes"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "before_revision": {"type": "string"},
    "after_revision": {"type": "string"},
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "change_type", "fields", "confidence", "evidence_state", "before_evidence_hash", "after_evidence_hash"],
        "properties": {
          "asset_id": {"type": "string"},
          "change_type": {"enum": ["added", "removed", "modified"]},
          "fields": {
            "type": "object",
            "properties": {
              "algorithm": {"$ref": "#/$defs/fieldChange"},
              "parameters": {"$ref": "#/$defs/fieldChange"},
              "mode": {"$ref": "#/$defs/fieldChange"},
              "protocol": {"$ref": "#/$defs/fieldChange"},
              "provider_boundary": {"$ref": "#/$defs/fieldChange"},
              "key_purpose": {"$ref": "#/$defs/fieldChange"},
              "fallback": {"$ref": "#/$defs/fieldChange"},
              "owner": {"$ref": "#/$defs/fieldChange"},
              "confidence": {"$ref": "#/$defs/fieldChange"},
              "evidence_hash": {"$ref": "#/$defs/fieldChange"}
            },
            "additionalProperties": false
          },
          "confidence": {"enum": ["high", "medium", "low"]},
          "evidence_state": {"enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]},
          "before_evidence_hash": {"type": ["string", "null"]},
          "after_evidence_hash": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "fieldChange": {
      "type": "object",
      "required": ["before", "after"],
      "properties": {
        "before": {},
        "after": {}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
