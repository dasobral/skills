{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deterministic cryptographic evidence collection",
  "type": "object",
  "required": ["schema_version", "asset_candidates"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "asset_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "source_class", "location", "algorithm", "parameters", "mode", "protocol", "provider_boundary", "key_purpose", "fallback", "owner", "confidence", "evidence_state", "evidence_hash"],
        "properties": {
          "asset_id": {"type": "string"},
          "source_class": {"enum": ["source", "dependency", "configuration", "binary", "certificate"]},
          "location": {"type": "string"},
          "algorithm": {"type": "string"},
          "parameters": {
            "type": "object",
            "properties": {},
            "additionalProperties": false
          },
          "mode": {"type": "string"},
          "protocol": {"type": "string"},
          "provider_boundary": {"type": "string"},
          "key_purpose": {"type": "string"},
          "fallback": {"type": "string"},
          "owner": {"type": "string"},
          "confidence": {"enum": ["high", "medium", "low"]},
          "evidence_state": {"enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]},
          "evidence_hash": {
            "type": ["string", "null"],
            "pattern": "sha256:[0-9a-f]{64}"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
