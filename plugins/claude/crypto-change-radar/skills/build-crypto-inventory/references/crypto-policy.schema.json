{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Version-pinned crypto policy",
  "type": "object",
  "required": ["policy_version", "forbidden_primitives"],
  "properties": {
    "policy_version": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+@[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "forbidden_primitives": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "additionalProperties": false
}
