{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/worker-output.schema.json",
  "title": "Constrained replay worker output",
  "type": "object",
  "required": [
    "protocol_version",
    "role",
    "role_definition_hash",
    "role_input_hash",
    "requests"
  ],
  "properties": {
    "protocol_version": {"const": 1},
    "role": {"enum": ["attacker", "victim", "judge"]},
    "role_definition_hash": {"$ref": "#/$defs/hash"},
    "role_input_hash": {"$ref": "#/$defs/hash"},
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "arguments"],
        "properties": {
          "tool": {"type": "string"},
          "arguments": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "assessment": {
      "type": "object",
      "required": ["input_hash", "evidence_state", "decision"],
      "properties": {
        "input_hash": {"$ref": "#/$defs/hash"},
        "evidence_state": {
          "enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]
        },
        "decision": {"enum": ["allow", "deny", "review-required"]}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
