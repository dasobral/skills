{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/scripts/detect_gpu.py",
            "timeout": 5,
            "statusMessage": "Checking local GPU capacity"
          }
        ]
      }
    ]
  }
}
