# Skills framework — cron configuration
# Copy to config.env and edit, or pass flags to install.sh.
# install.sh loads this file when present.

# Absolute path to the skills repo (required for cron).
# Leave empty to auto-detect from this script's location.
SKILLS_REPO=

# Crontab schedule (default: every 6 hours at :00)
SCHEDULE=0 */6 * * *

# Interpreter used by the wrapper (must see PyYAML)
PYTHON=/usr/bin/python3

# Log file relative to SKILLS_REPO, or absolute
LOG_FILE=landing/maintain.log

# Minimal cron environment
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# Marker comment — do not change unless uninstalling a custom install
CRON_MARKER=# skills-framework-maintain
