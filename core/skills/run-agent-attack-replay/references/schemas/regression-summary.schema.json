{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/regression-summary.schema.json",
  "title": "Hash-bound isolated replay regression summary",
  "type": "object",
  "required": [
    "schema_version",
    "scenario_hash",
    "scenario_policy",
    "role_definition_hashes",
    "worker_attestations",
    "harness",
    "counts",
    "attack_success_interval",
    "benign_utility_interval",
    "trials",
    "evidence_state",
    "summary_hash"
  ],
  "properties": {
    "schema_version": {"const": "3.0"},
    "scenario_hash": {"$ref": "#/$defs/hash"},
    "scenario_policy": {
      "type": "object",
      "required": ["prohibited_side_effects", "benign_criteria", "fixture_set_hash"],
      "properties": {
        "prohibited_side_effects": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "benign_criteria": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "fixture_set_hash": {"$ref": "#/$defs/hash"}
      },
      "additionalProperties": false
    },
    "role_definition_hashes": {
      "type": "object",
      "required": ["attacker", "victim", "judge"],
      "properties": {
        "attacker": {"$ref": "#/$defs/hash"},
        "victim": {"$ref": "#/$defs/hash"},
        "judge": {"$ref": "#/$defs/hash"}
      },
      "additionalProperties": false
    },
    "worker_attestations": {
      "type": "object",
      "required": ["attacker", "victim", "judge"],
      "additionalProperties": {"$ref": "#/$defs/worker_attestation"}
    },
    "harness": {
      "type": "object",
      "required": ["workspace", "filesystem", "network", "side_effect_monitor", "arbitrary_code_execution", "roles", "executor_mode", "sandbox_profile"],
      "properties": {
        "workspace": {"const": "temporary-directory"},
        "filesystem": {"const": "contained-mediated-paths"},
        "network": {"const": "deny-all-mediated"},
        "side_effect_monitor": {"const": "parent-owned-hash-chained-observations"},
        "arbitrary_code_execution": {"const": false},
        "roles": {"const": "separate-subprocesses"},
        "executor_mode": {"enum": ["isolated-agent-executor", "scripted-self-test"]},
        "sandbox_profile": {"enum": ["bubblewrap-minimal-runtime-v1", "not-applicable"]}
      },
      "additionalProperties": false
    },
    "counts": {
      "type": "object",
      "required": ["trials", "attack_successes", "benign_successes"],
      "properties": {
        "trials": {"type": "integer", "minimum": 1},
        "attack_successes": {"type": "integer", "minimum": 0},
        "benign_successes": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "attack_success_interval": {"$ref": "#/$defs/wilson"},
    "benign_utility_interval": {"$ref": "#/$defs/wilson"},
    "trials": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "trial-result.schema.json"}
    },
    "evidence_state": {"$ref": "#/$defs/evidence_state"},
    "summary_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "wilson": {
      "type": "object",
      "required": ["method", "confidence", "lower", "upper"],
      "properties": {
        "method": {"const": "wilson"},
        "confidence": {"const": 0.95},
        "lower": {"type": "number", "minimum": 0, "maximum": 1},
        "upper": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "worker_attestation": {
      "type": "object",
      "required": ["execution", "role_definition_hash", "sent_envelope_hashes", "received_envelope_hashes", "invocations"],
      "properties": {
        "execution": {"enum": ["isolated-agent-executor", "scripted-self-test"]},
        "role_definition_hash": {"$ref": "#/$defs/hash"},
        "sent_envelope_hashes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/hash"}},
        "received_envelope_hashes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/hash"}},
        "invocations": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "evidence_state": {
      "enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]
    }
  },
  "additionalProperties": false
}
