{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dasobral.example/schemas/uncertainty-statement.schema.json",
  "title": "Uncertainty statement",
  "type": "object",
  "additionalProperties": false,
  "required": ["quantity", "meaning", "method", "coverage_probability", "interval", "unit", "limitations"],
  "properties": {
    "quantity": {"type": "string", "minLength": 1},
    "meaning": {"enum": ["aleatory", "epistemic", "combined", "predictive", "confidence"]},
    "method": {"type": "string", "minLength": 1},
    "coverage_probability": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
    "interval": {
      "type": "array",
      "prefixItems": [{"type": "number"}, {"type": "number"}],
      "minItems": 2,
      "maxItems": 2
    },
    "unit": {"type": "string", "minLength": 1},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
