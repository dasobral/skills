{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dasobral.example/schemas/run-record.schema.json",
  "title": "Scientific run record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "context_of_use",
    "quantity_of_interest",
    "unit_registry",
    "coordinate_frame",
    "tolerances",
    "uncertainty",
    "acceptance_threshold",
    "source_revision",
    "input_hashes",
    "artifacts",
    "environment",
    "compiler_settings",
    "runtime_settings",
    "hardware",
    "parallel_layout",
    "seeds",
    "replay_command",
    "reproducibility_class",
    "results"
  ],
  "properties": {
    "run_id": {"type": "string", "pattern": "^run-sha256:[0-9a-f]{64}$"},
    "context_of_use": {"type": "string", "minLength": 1},
    "quantity_of_interest": {"type": "string", "minLength": 1},
    "unit_registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quantities"],
      "properties": {
        "quantities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "unit", "dimension", "coordinate_frame"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "unit": {"type": "string", "minLength": 1},
              "dimension": {"type": "string", "minLength": 1},
              "coordinate_frame": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "coordinate_frame": {"type": "string", "minLength": 1},
    "tolerances": {
      "type": "object",
      "additionalProperties": false,
      "required": ["absolute", "relative"],
      "properties": {
        "absolute": {"type": "number", "minimum": 0},
        "relative": {"type": "number", "minimum": 0}
      }
    },
    "uncertainty": {"$ref": "#/$defs/uncertaintyEvidence"},
    "acceptance_threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator", "value", "unit"],
      "properties": {
        "operator": {"enum": ["<", "<=", ">", ">=", "=="]},
        "value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1}
      }
    },
    "source_revision": {"$ref": "#/$defs/stringEvidence"},
    "input_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/hashEvidence"}
    },
    "artifacts": {
      "type": "object",
      "propertyNames": {
        "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.(?:/|$)).+"
      },
      "additionalProperties": {"$ref": "#/$defs/hashEvidence"}
    },
    "environment": {"$ref": "#/$defs/objectEvidence"},
    "compiler_settings": {"$ref": "#/$defs/objectEvidence"},
    "runtime_settings": {"$ref": "#/$defs/objectEvidence"},
    "hardware": {"$ref": "#/$defs/objectEvidence"},
    "parallel_layout": {"$ref": "#/$defs/objectEvidence"},
    "seeds": {"$ref": "#/$defs/seedEvidence"},
    "replay_command": {"$ref": "#/$defs/commandEvidence"},
    "reproducibility_class": {
      "enum": ["bitwise", "numerically-equivalent", "scientifically-equivalent"]
    },
    "results": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "number"}
    }
  },
  "$defs": {
    "uncertaintyStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quantity", "meaning", "method", "coverage_probability", "interval", "unit", "limitations"],
      "properties": {
        "quantity": {"type": "string", "minLength": 1},
        "meaning": {"enum": ["aleatory", "epistemic", "combined", "predictive", "confidence"]},
        "method": {"type": "string", "minLength": 1},
        "coverage_probability": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "interval": {
          "type": "array",
          "prefixItems": [{"type": "number"}, {"type": "number"}],
          "minItems": 2,
          "maxItems": 2
        },
        "unit": {"type": "string", "minLength": 1},
        "limitations": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidenceBase": {
      "type": "object",
      "required": ["state", "value", "reason"],
      "properties": {
        "state": {"enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]},
        "value": {},
        "reason": {"type": "string"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"state": {"const": "pass"}},
            "required": ["state"]
          },
          "then": {"properties": {"value": {"not": {"type": "null"}}}}
        }
      ]
    },
    "stringEvidence": {
      "allOf": [
        {"$ref": "#/$defs/evidenceBase"},
        {
          "properties": {
            "value": {
              "oneOf": [
                {"type": "null"},
                {"type": "string", "minLength": 1}
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "uncertaintyEvidence": {
      "allOf": [
        {"$ref": "#/$defs/evidenceBase"},
        {
          "properties": {
            "value": {
              "oneOf": [
                {"type": "null"},
                {"$ref": "#/$defs/uncertaintyStatement"}
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "objectEvidence": {
      "allOf": [
        {"$ref": "#/$defs/evidenceBase"},
        {
          "properties": {
            "value": {
              "oneOf": [
                {"type": "null"},
                {"type": "object"}
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "seedEvidence": {
      "allOf": [
        {"$ref": "#/$defs/evidenceBase"},
        {
          "properties": {
            "value": {
              "oneOf": [
                {"type": "null"},
                {
                  "type": "array",
                  "minItems": 1,
                  "items": {"type": "integer"}
                }
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "commandEvidence": {
      "allOf": [
        {"$ref": "#/$defs/evidenceBase"},
        {
          "properties": {
            "value": {
              "oneOf": [
                {"type": "null"},
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["argv", "executable_hash", "redacted_arguments"],
                  "properties": {
                    "argv": {
                      "type": "array",
                      "minItems": 1,
                      "items": {"type": "string", "minLength": 1}
                    },
                    "executable_hash": {
                      "oneOf": [
                        {"type": "null"},
                        {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
                      ]
                    },
                    "redacted_arguments": {
                      "type": "array",
                      "uniqueItems": true,
                      "items": {"type": "string", "minLength": 1}
                    }
                  }
                }
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "hashEvidence": {
      "allOf": [
        {"$ref": "#/$defs/evidenceBase"},
        {
          "properties": {
            "value": {
              "oneOf": [
                {"type": "null"},
                {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  }
}
