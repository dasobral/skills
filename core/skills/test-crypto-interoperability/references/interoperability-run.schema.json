{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Executable interoperability run",
  "type": "object",
  "required": ["schema_version", "runner", "execution", "case_record"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "runner": {
      "type": "object",
      "required": ["argv", "timeout_seconds", "policy"],
      "properties": {
        "argv": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 60},
        "policy": {
          "type": "object",
          "required": ["executable", "executable_sha256", "workdir_policy", "sandbox_profile", "approved_inputs"],
          "properties": {
            "executable": {"type": ["string", "null"]},
            "executable_sha256": {
              "type": ["string", "null"],
              "pattern": "sha256:[0-9a-f]{64}"
            },
            "workdir_policy": {
              "enum": ["isolated-temporary-directory", null]
            },
            "sandbox_profile": {
              "enum": ["bubblewrap-full-isolation", null]
            },
            "approved_inputs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["host_path", "sandbox_path", "sha256"],
                "properties": {
                  "host_path": {"type": "string"},
                  "sandbox_path": {"type": "string", "pattern": "^/inputs/[A-Za-z0-9._-]+$"},
                  "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": ["evidence_state", "exit_code", "stdout_hash", "stderr_hash", "sandbox_profile", "workdir_policy", "guidance"],
      "properties": {
        "evidence_state": {"enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]},
        "exit_code": {"type": ["integer", "null"]},
        "stdout_hash": {"type": ["string", "null"], "pattern": "sha256:[0-9a-f]{64}"},
        "stderr_hash": {"type": ["string", "null"], "pattern": "sha256:[0-9a-f]{64}"},
        "sandbox_profile": {"type": ["string", "null"]},
        "workdir_policy": {"type": ["string", "null"]},
        "guidance": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "case_record": {
      "type": "object",
      "required": ["case_id", "evidence_state", "record_hash"],
      "properties": {
        "case_id": {"type": "string"},
        "evidence_state": {"enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]},
        "record_hash": {"type": "string", "pattern": "sha256:[0-9a-f]{64}"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
