{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/trust-ledger-entry.schema.json",
  "title": "Authenticated repository trust ledger entry",
  "type": "object",
  "required": [
    "schema_version",
    "sequence",
    "previous_entry_hmac",
    "artifact_hash",
    "decision_binding_hash",
    "applicability_hash",
    "prior_approved_snapshot_hash",
    "decision",
    "policy",
    "approver",
    "entry_hmac"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "sequence": {"type": "integer", "minimum": 1},
    "previous_entry_hmac": {"$ref": "#/$defs/hmac"},
    "artifact_hash": {"$ref": "#/$defs/hash"},
    "decision_binding_hash": {"$ref": "#/$defs/hash"},
    "applicability_hash": {"$ref": "#/$defs/hash"},
    "prior_approved_snapshot_hash": {
      "anyOf": [{"$ref": "#/$defs/hash"}, {"type": "null"}]
    },
    "decision": {"enum": ["allow", "deny", "review-required"]},
    "policy": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {"type": ["string", "null"]},
        "version": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "approver": {
      "type": "object",
      "required": ["id"],
      "properties": {"id": {"type": ["string", "null"]}},
      "additionalProperties": false
    },
    "entry_hmac": {"$ref": "#/$defs/hmac"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "hmac": {"type": "string", "pattern": "^hmac-sha256:[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
