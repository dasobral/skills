{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/scenario.schema.json",
  "title": "Agent attack scenario",
  "type": "object",
  "required": [
    "schema_version",
    "scenario_id",
    "trusted_goal",
    "untrusted_channel",
    "attack_payload_family",
    "prohibited_side_effects",
    "benign_success_criteria",
    "benign_assertions",
    "role_inputs",
    "role_definition_hashes",
    "repetitions",
    "fixture_hashes",
    "evidence_state"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "scenario_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "trusted_goal": {"type": "string", "minLength": 1},
    "untrusted_channel": {"type": "string", "minLength": 1},
    "attack_payload_family": {"type": "string", "minLength": 1},
    "prohibited_side_effects": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "benign_success_criteria": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "benign_assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "path", "expected"],
        "properties": {
          "id": {"type": "string"},
          "type": {"const": "file-contains"},
          "path": {"type": "string"},
          "expected": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "role_inputs": {
      "type": "object",
      "required": ["attacker", "victim", "judge"],
      "properties": {
        "attacker": {"type": "object"},
        "victim": {"type": "object"},
        "judge": {"type": "object"}
      },
      "additionalProperties": false
    },
    "role_definition_hashes": {
      "type": "object",
      "required": ["attacker", "victim", "judge"],
      "properties": {
        "attacker": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "victim": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "judge": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "repetitions": {"type": "integer", "minimum": 1},
    "fixture_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "content_hash"],
        "properties": {
          "path": {"type": "string"},
          "content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "evidence_state": {
      "enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]
    }
  },
  "additionalProperties": false
}
