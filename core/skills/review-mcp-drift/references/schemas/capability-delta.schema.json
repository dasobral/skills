{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-security/capability-delta.schema.json",
  "title": "MCP capability and policy delta",
  "type": "object",
  "required": ["schema_version", "before_hash", "after_hash", "changes", "instruction_findings", "remote_descriptor_changes", "security_checks", "evidence_state", "decision"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "before_hash": {"$ref": "#/$defs/hash"},
    "after_hash": {"$ref": "#/$defs/hash"},
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "tool_name", "change_type", "before_hash", "after_hash", "evidence_state", "decision"],
        "properties": {
          "field": {
            "enum": ["tool", "tool-schema", "description", "destructive-capability", "auth-endpoint", "package-identity", "scopes"]
          },
          "tool_name": {"type": ["string", "null"]},
          "change_type": {"enum": ["added", "removed", "modified"]},
          "before_hash": {"$ref": "#/$defs/hash"},
          "after_hash": {"$ref": "#/$defs/hash"},
          "evidence_state": {"$ref": "#/$defs/evidence_state"},
          "decision": {"$ref": "#/$defs/decision"}
        },
        "additionalProperties": false
      }
    },
    "security_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "evidence_state", "decision", "evidence"],
        "properties": {
          "check": {
            "enum": [
              "shadowed-names",
              "scope-expansion",
              "hidden-instructions",
              "token-passthrough",
              "remote-mutability",
              "destructive-capability-addition"
            ]
          },
          "evidence_state": {"$ref": "#/$defs/evidence_state"},
          "decision": {"$ref": "#/$defs/decision"},
          "evidence": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "instruction_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["location", "source_class", "content_hash", "evidence_state", "decision", "policy_action"],
        "properties": {
          "location": {"type": "string", "pattern": "^/"},
          "source_class": {"enum": ["server-instructions", "tool-description", "schema-annotation", "remote-descriptor"]},
          "content_hash": {"$ref": "#/$defs/hash"},
          "evidence_state": {"$ref": "#/$defs/evidence_state"},
          "decision": {"$ref": "#/$defs/decision"},
          "policy_action": {"enum": ["review", "block"]}
        },
        "additionalProperties": false
      }
    },
    "remote_descriptor_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["location", "before_hash", "after_hash", "evidence_state", "decision", "policy_action"],
        "properties": {
          "location": {"type": "string", "pattern": "^/"},
          "before_hash": {"$ref": "#/$defs/hash"},
          "after_hash": {"$ref": "#/$defs/hash"},
          "evidence_state": {"$ref": "#/$defs/evidence_state"},
          "decision": {"$ref": "#/$defs/decision"},
          "policy_action": {"enum": ["review", "block"]}
        },
        "additionalProperties": false
      }
    },
    "evidence_state": {"$ref": "#/$defs/evidence_state"},
    "decision": {"$ref": "#/$defs/decision"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "decision": {"enum": ["allow", "deny", "review-required"]},
    "evidence_state": {
      "enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]
    }
  },
  "additionalProperties": false
}
