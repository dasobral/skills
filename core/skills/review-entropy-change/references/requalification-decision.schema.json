{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entropy source requalification decision",
  "type": "object",
  "required": ["schema_version", "source_id", "evidence_state", "decision", "changed_fields", "reasons", "policy_revision", "limitations"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "source_id": {"type": "string"},
    "evidence_state": {"enum": ["pass", "fail", "unknown", "not-applicable", "evidence-gap"]},
    "decision": {"enum": ["requalification-required", "review-required", "no-material-change"]},
    "changed_fields": {"type": "array", "items": {"type": "string"}},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "policy_revision": {"type": ["string", "null"]},
    "limitations": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
