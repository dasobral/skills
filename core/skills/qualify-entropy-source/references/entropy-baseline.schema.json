{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Approved entropy source baseline",
  "type": "object",
  "required": ["baseline_version", "source_identity", "source_identity_hash"],
  "properties": {
    "baseline_version": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+@[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "source_identity": {
      "type": "object",
      "required": ["source_id", "source_physics", "adversarial_assumptions", "raw_sampling_point", "digitization", "conditioning", "hardware_identity", "firmware_identity", "driver_identity", "sampling_rate_hz", "alphabet_size", "claimed_min_entropy_bits_per_sample", "operating_envelope"],
      "properties": {
        "source_id": {"type": "string"},
        "source_physics": {"type": "string"},
        "adversarial_assumptions": {"type": "array", "items": {"type": "string"}},
        "raw_sampling_point": {"type": "string"},
        "digitization": {"type": "string"},
        "conditioning": {"type": "string"},
        "hardware_identity": {"type": "string"},
        "firmware_identity": {"type": "string"},
        "driver_identity": {"type": "string"},
        "sampling_rate_hz": {"type": "number", "exclusiveMinimum": 0},
        "alphabet_size": {"type": "integer", "minimum": 2},
        "claimed_min_entropy_bits_per_sample": {"type": "number", "exclusiveMinimum": 0},
        "operating_envelope": {
          "type": "object",
          "required": ["temperature_c", "voltage_v"],
          "properties": {
            "temperature_c": {"$ref": "#/$defs/range"},
            "voltage_v": {"$ref": "#/$defs/range"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "source_identity_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "$defs": {
    "range": {
      "type": "object",
      "required": ["minimum", "maximum"],
      "properties": {
        "minimum": {"type": "number"},
        "maximum": {"type": "number"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
