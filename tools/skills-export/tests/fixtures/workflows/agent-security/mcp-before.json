{
  "server": {
    "package": {
      "name": "@example/safe-mcp",
      "version": "1.0.0",
      "integrity": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    },
    "auth_endpoint": "https://auth.example.test/oauth",
    "scopes": ["repository:read"],
    "token_passthrough": false,
    "instructions": "Read repository metadata.",
    "tools": [
      {
        "name": "safe-read",
        "description": "Read one repository path.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {"type": "string"}
          },
          "required": ["path"]
        }
      },
      {
        "name": "safe-status",
        "description": "Read server status.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      }
    ]
  }
}
